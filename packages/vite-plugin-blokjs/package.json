{
  "name": "vite-plugin-blokjs",
  "version": "0.1.1",
  "description": "Vite plugin for BlokJS - auto-discovers components and stores by filename convention",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@maleta/blokjs": "^0.1.0",
    "vite": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@maleta/blokjs": "workspace:*",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "license": "MIT",
  "author": "maleta",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maleta/blokjs.git"
  },
  "bugs": {
    "url": "https://github.com/maleta/blokjs/issues"
  },
  "homepage": "https://github.com/maleta/blokjs/tree/main/packages/vite-plugin-blokjs",
  "keywords": ["vite", "vite-plugin", "blokjs", "auto-discovery", "components"]
}
